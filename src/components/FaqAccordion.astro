---
interface Faq {
  q: string;
  a: string;
}

interface Props {
  faqs: Faq[];
}

const { faqs } = Astro.props;
---

<div class="space-y-3">
  {faqs.map((faq, i) => (
    <details class="group border border-stone-200 rounded-xl overflow-hidden">
      <summary class="flex items-center justify-between gap-4 px-6 py-4 cursor-pointer
                      list-none bg-white hover:bg-stone-50 transition-colors select-none">
        <span class="font-medium text-stone-800">{faq.q}</span>
        <svg
          class="w-4 h-4 text-terracotta flex-shrink-0 transition-transform duration-200 group-open:rotate-180"
          fill="none" stroke="currentColor" viewBox="0 0 24 24"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </summary>
      <div class="px-6 py-4 text-stone-600 text-sm leading-relaxed bg-stone-50 border-t border-stone-100">
        {faq.a}
      </div>
    </details>
  ))}
</div>
