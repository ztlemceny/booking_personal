---
import { useTranslations, type Lang } from '../utils/i18n';
import partnersData from '../data/partners.json';

interface Props {
  lang: Lang;
  compact?: boolean;
}

const { lang, compact = false } = Astro.props;
const t = useTranslations(lang);
const isRTL = lang === 'ar';

const amenityIcons: Record<string, string> = {
  wifi: '📶',
  pool: '🏊',
  restaurant: '🍽️',
  parking: '🅿️',
  spa: '🧖',
  terrace: '🌿',
};

const displayedPartners = compact ? partnersData.slice(0, 3) : partnersData;
---

<section class={`partners-section ${compact ? 'py-16' : 'py-24'} bg-gradient-to-b from-stone-50 to-white`} id="partners">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class={`max-w-2xl mx-auto text-center mb-14 reveal ${isRTL ? 'dir-rtl' : ''}`}>
      <span class="inline-block px-4 py-1.5 bg-gold/15 text-amber-700 text-xs font-bold uppercase tracking-widest rounded-full mb-4">
        {t.partners.section_title}
      </span>
      <h2 class="section-title">{t.partners.page_title}</h2>
      <p class="section-subtitle">{t.partners.section_subtitle}</p>
    </div>

    <div class={`grid grid-cols-1 md:grid-cols-2 ${compact ? 'lg:grid-cols-3' : 'lg:grid-cols-2 xl:grid-cols-4'} gap-7`}>
      {displayedPartners.map((hotel) => {
        const desc = lang === 'ar' ? hotel.description_ar : lang === 'fr' ? hotel.description_fr : hotel.description_en;
        const badge = lang === 'ar' ? hotel.badge_ar : lang === 'fr' ? hotel.badge_fr : hotel.badge_en;

        return (
          <article class="partner-card group rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-400 bg-white border border-stone-100">

            <!-- Hotel image -->
            <div class="relative overflow-hidden h-48">
              <img
                src={hotel.image}
                alt={hotel.name}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent" />
              <!-- Badge -->
              <span class="absolute top-3 left-3 bg-gold text-white text-[11px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full shadow">
                {badge}
              </span>
              <!-- Stars -->
              <div class="absolute bottom-3 left-3 flex gap-0.5">
                {Array.from({ length: hotel.stars }).map(() => (
                  <svg class="w-4 h-4 text-gold fill-gold" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                ))}
              </div>
            </div>

            <!-- Content -->
            <div class={`p-5 ${isRTL ? 'text-right' : ''}`} dir={isRTL ? 'rtl' : 'ltr'}>
              <div class="flex items-start justify-between gap-2 mb-2">
                <h3 class="font-heading font-bold text-stone-900 text-base leading-tight">{hotel.name}</h3>
                <span class="shrink-0 text-sm font-bold text-terracotta">{hotel.priceRange}</span>
              </div>

              <p class="text-stone-500 text-sm leading-relaxed mb-4 line-clamp-2">{desc}</p>

              <!-- Amenities -->
              <div class={`flex flex-wrap gap-1.5 mb-5 ${isRTL ? 'flex-row-reverse' : ''}`}>
                {hotel.amenities.map((a) => (
                  <span class="text-xs bg-sand-50 text-stone-600 border border-stone-100 px-2 py-0.5 rounded-md">
                    {amenityIcons[a] || '✓'} {a}
                  </span>
                ))}
              </div>

              <!-- Price + CTA -->
              <div class={`flex items-center justify-between border-t border-stone-100 pt-4 ${isRTL ? 'flex-row-reverse' : ''}`}>
                <div>
                  <span class="text-xs text-stone-400">{t.partners.from_label}</span>
                  <span class="block font-bold text-stone-900">€{hotel.priceFrom} <span class="text-xs font-normal text-stone-400">{t.partners.per_night}</span></span>
                </div>
                <a
                  href={hotel.affiliateUrl}
                  target="_blank"
                  rel="noopener noreferrer sponsored"
                  class="inline-flex items-center gap-1.5 bg-[#003580] hover:bg-[#00285e] text-white text-xs font-semibold px-4 py-2.5 rounded-xl transition-colors shadow-sm"
                >
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" opacity="0"/><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/></svg>
                  {t.partners.book_button}
                </a>
              </div>
            </div>

          </article>
        );
      })}
    </div>

    <!-- Affiliate disclaimer -->
    <p class={`text-center text-xs text-stone-400 mt-10 max-w-xl mx-auto ${isRTL ? 'dir-rtl' : ''}`} dir={isRTL ? 'rtl' : 'ltr'}>
      {t.partners.affiliate_note}
    </p>

    {compact && (
      <div class="text-center mt-10">
        <a
          href={`${import.meta.env.BASE_URL}${lang}/partners`.replace(/\/+/g, '/')}
          class="btn-outline-dark"
        >
          {t.partners.page_title} →
        </a>
      </div>
    )}

  </div>
</section>

<style>
  .fill-gold { fill: #c9a227; }
  .text-gold { color: #c9a227; }
  .bg-gold { background-color: #c9a227; }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .dir-rtl { direction: rtl; }
</style>
