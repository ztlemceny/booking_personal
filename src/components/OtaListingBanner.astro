---
import { useTranslations, type Lang } from '../utils/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const isRTL = lang === 'ar';

// Replace these with real listing URLs once you create the listings
const GYG_URL = 'https://www.getyourguide.com/tlemcen-l107693/';
const VIATOR_URL = 'https://www.viator.com/Tlemcen/d50749-ttd/';
---

<section class="ota-banner py-20 bg-olive-dark relative overflow-hidden" id="book-online">

  <!-- Background texture -->
  <div class="absolute inset-0 opacity-5">
    <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg"><defs><pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse"><path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="0.5"/></pattern></defs><rect width="100%" height="100%" fill="url(#grid)"/></svg>
  </div>

  <!-- Glow orbs -->
  <div class="absolute -top-20 -left-20 w-72 h-72 bg-gold/10 rounded-full blur-3xl pointer-events-none" />
  <div class="absolute -bottom-20 -right-20 w-72 h-72 bg-terracotta/10 rounded-full blur-3xl pointer-events-none" />

  <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class={`text-center mb-12 ${isRTL ? 'dir-rtl' : ''}`} dir={isRTL ? 'rtl' : 'ltr'}>
      <span class="inline-block text-gold text-xs font-bold uppercase tracking-widest mb-3">🌍 {t.ota_banner.title}</span>
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-3">{t.ota_banner.subtitle}</h2>
      <div class="w-16 h-0.5 bg-gold mx-auto" />
    </div>

    <div class={`flex flex-col sm:flex-row items-center justify-center gap-6 ${isRTL ? 'flex-row-reverse' : ''}`}>

      <!-- GetYourGuide -->
      <a
        href={GYG_URL}
        target="_blank"
        rel="noopener noreferrer"
        id="ota-gyg-link"
        class="ota-card group w-full sm:w-72 rounded-2xl border border-white/10 bg-white/5 hover:bg-white/10 backdrop-blur-sm p-6 transition-all duration-300 hover:border-gold/30 hover:shadow-lg hover:shadow-gold/10 flex items-center gap-4"
      >
        <div class="shrink-0 w-14 h-14 bg-[#FF5533] rounded-xl flex items-center justify-center shadow-lg">
          <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm0 18a8 8 0 110-16 8 8 0 010 16zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"/></svg>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-white font-bold text-base">{t.ota_banner.gyg_label}</p>
          <p class="text-stone-400 text-xs mt-0.5 truncate">getYourGuide.com</p>
          <span class="inline-flex items-center gap-1 text-gold text-xs font-semibold mt-2 group-hover:gap-2 transition-all">
            {t.ota_banner.cta}
          </span>
        </div>
      </a>

      <!-- Viator -->
      <a
        href={VIATOR_URL}
        target="_blank"
        rel="noopener noreferrer"
        id="ota-viator-link"
        class="ota-card group w-full sm:w-72 rounded-2xl border border-white/10 bg-white/5 hover:bg-white/10 backdrop-blur-sm p-6 transition-all duration-300 hover:border-gold/30 hover:shadow-lg hover:shadow-gold/10 flex items-center gap-4"
      >
        <div class="shrink-0 w-14 h-14 bg-[#34E0A1] rounded-xl flex items-center justify-center shadow-lg">
          <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M17 12h-5v5h5v-5zM16 1v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2h-1V1h-2zm3 18H5V8h14v11z"/></svg>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-white font-bold text-base">{t.ota_banner.viator_label}</p>
          <p class="text-stone-400 text-xs mt-0.5 truncate">viator.com / tripadvisor.com</p>
          <span class="inline-flex items-center gap-1 text-gold text-xs font-semibold mt-2 group-hover:gap-2 transition-all">
            {t.ota_banner.cta}
          </span>
        </div>
      </a>

    </div>
  </div>
</section>

<style>
  .dir-rtl { direction: rtl; }
  .ota-card { cursor: pointer; }
</style>
