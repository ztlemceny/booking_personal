---
import { useTranslations, type Lang } from '../utils/i18n';
import { SITE } from '../config';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const isRTL = lang === 'ar';

const addons = [
  { id: 'photo', emoji: '📸', labelKey: 'photo_label', descKey: 'photo_desc', price: 20 },
  { id: 'transport', emoji: '🚗', labelKey: 'transport_label', descKey: 'transport_desc', price: 15 },
  { id: 'meal', emoji: '🍽️', labelKey: 'meal_label', descKey: 'meal_desc', price: 10 },
  { id: 'souvenir', emoji: '🎁', labelKey: 'souvenir_label', descKey: 'souvenir_desc', price: 15 },
];
---

<section class="addons-section py-20 bg-gradient-to-b from-white to-stone-50" id="tour-addons">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class={`max-w-2xl mx-auto text-center mb-14 reveal ${isRTL ? 'dir-rtl' : ''}`} dir={isRTL ? 'rtl' : 'ltr'}>
      <span class="inline-block px-4 py-1.5 bg-terracotta/10 text-terracotta text-xs font-bold uppercase tracking-widest rounded-full mb-4">
        ✨ {t.addons.section_title}
      </span>
      <h2 class="section-title">{t.addons.section_title}</h2>
      <p class="section-subtitle">{t.addons.section_subtitle}</p>
    </div>

    <div id="addons-grid" class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-10">
      {addons.map((addon) => (
        <label
          class="addon-card group relative flex items-start gap-4 p-5 rounded-2xl border-2 border-stone-100 bg-white cursor-pointer transition-all duration-200 hover:border-terracotta/40 hover:shadow-md hover:shadow-terracotta/5 has-[:checked]:border-terracotta has-[:checked]:bg-terracotta/5 has-[:checked]:shadow-md"
          dir={isRTL ? 'rtl' : 'ltr'}
        >
          <input
            type="checkbox"
            class="addon-checkbox sr-only"
            data-id={addon.id}
            data-label={t.addons[addon.labelKey as keyof typeof t.addons]}
            data-price={addon.price}
          />

          <!-- Emoji icon -->
          <div class="shrink-0 w-12 h-12 rounded-xl bg-stone-50 group-[has-[:checked]:]:bg-terracotta/10 flex items-center justify-center text-2xl transition-colors">
            {addon.emoji}
          </div>

          <!-- Text -->
          <div class="flex-1 min-w-0">
            <div class="flex items-center justify-between gap-2">
              <p class="font-semibold text-stone-900 text-sm">{t.addons[addon.labelKey as keyof typeof t.addons]}</p>
              <span class="shrink-0 font-bold text-terracotta text-sm">+€{addon.price}</span>
            </div>
            <p class="text-stone-500 text-xs mt-1">{t.addons[addon.descKey as keyof typeof t.addons]}</p>
          </div>

          <!-- Checkmark indicator -->
          <div class="addon-checkmark absolute top-3 right-3 w-5 h-5 rounded-full border-2 border-stone-200 flex items-center justify-center transition-all">
            <svg class="w-3 h-3 text-white hidden" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
          </div>
        </label>
      ))}
    </div>

    <!-- Summary bar -->
    <div id="addon-summary" class="hidden addon-summary rounded-2xl bg-olive-dark text-white p-5 flex flex-col sm:flex-row items-center justify-between gap-4 shadow-xl" dir={isRTL ? 'rtl' : 'ltr'}>
      <div>
        <p class="text-xs text-stone-300 mb-1">{t.addons.selected_label}</p>
        <p id="addon-summary-text" class="font-semibold text-sm"></p>
      </div>
      <div class="flex items-center gap-4">
        <div class="text-right">
          <p class="text-xs text-stone-300">{t.addons.total_extra}</p>
          <p id="addon-total" class="font-bold text-gold text-lg"></p>
        </div>
        <a
          id="addon-whatsapp-btn"
          href="#"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-[#25d366] hover:bg-[#1db355] text-white font-semibold text-sm px-5 py-3 rounded-xl transition-colors shadow"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Book with Add-ons
        </a>
      </div>
    </div>

  </div>
</section>

<script define:vars={{ whatsappNumber: SITE.whatsappNumber, addonLine: t.addons.whatsapp_addon_line }}>
  function initAddons() {
    const checkboxes = document.querySelectorAll('.addon-checkbox');
    const summary = document.getElementById('addon-summary');
    const summaryText = document.getElementById('addon-summary-text');
    const totalEl = document.getElementById('addon-total');
    const waBtn = document.getElementById('addon-whatsapp-btn');

    function update() {
      const selected = [];
      let total = 0;

      checkboxes.forEach((cb) => {
        const el = cb;
        const card = el.closest('label');
        const checkmark = card?.querySelector('.addon-checkmark');
        const checkIcon = checkmark?.querySelector('svg');

        if (el.checked) {
          selected.push({ label: el.dataset.label, price: parseInt(el.dataset.price) });
          total += parseInt(el.dataset.price);
          checkmark?.classList.add('bg-terracotta', 'border-terracotta');
          checkIcon?.classList.remove('hidden');
        } else {
          checkmark?.classList.remove('bg-terracotta', 'border-terracotta');
          checkIcon?.classList.add('hidden');
        }
      });

      if (selected.length > 0 && summary && summaryText && totalEl && waBtn) {
        summary.classList.remove('hidden');
        summaryText.textContent = selected.map(s => s.label).join(', ');
        totalEl.textContent = `+€${total}`;

        const addonNames = selected.map(s => s.label).join(', ');
        const line = addonLine
          .replace('{addons}', addonNames)
          .replace('{extra}', `€${total}`);

        const msg = `Hello Hamza!\n\nI would like to book a tour and add the following extras:\n\n${line}\n\nPlease send me availability and total pricing.`;
        const url = `https://wa.me/${whatsappNumber.replace(/\D/g, '')}?text=${encodeURIComponent(msg)}`;
        waBtn.href = url;
      } else {
        summary?.classList.add('hidden');
      }
    }

    checkboxes.forEach(cb => cb.addEventListener('change', update));
  }

  initAddons();
  document.addEventListener('astro:page-load', initAddons);
</script>

<style>
  .dir-rtl { direction: rtl; }
  label.addon-card:has(.addon-checkbox:checked) .addon-checkmark {
    background-color: var(--color-terracotta, #b94b2a);
    border-color: var(--color-terracotta, #b94b2a);
  }
  label.addon-card:has(.addon-checkbox:checked) .addon-checkmark svg {
    display: block;
  }
</style>
