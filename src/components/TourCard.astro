---
import { useTranslations, type Lang } from '../utils/i18n';
import { SITE } from '../config';
import type { CollectionEntry } from 'astro:content';

interface Props {
  tour: CollectionEntry<'tours'>;
  lang: Lang;
  compact?: boolean;
}

const { tour, lang, compact = false } = Astro.props;
const t = useTranslations(lang);
const { title, tagline, duration, difficulty, images, included, not_included, price, itinerary } = tour.data;
const mainImage = images[0] ?? '/images/shots/shot-01.jpg';

const [slug] = tour.slug.split('.');
const tourLink = `${import.meta.env.BASE_URL}/${lang}/tours/${slug}`.replace(/\/+/g, '/');

const whatsappMessage = t.tours.whatsapp_message_template
  .replace('{title}', title)
  .replace('{price}', price || t.tours.price_value);
const whatsappUrl = `${SITE.whatsappUrl}?text=${encodeURIComponent(whatsappMessage)}`;
---

<article class="card flex flex-col h-full group">
  <!-- Image -->
  <a href={tourLink} class="relative overflow-hidden aspect-[4/3] watermark block group-hover:opacity-90 transition-opacity">
    <img
      src={mainImage.startsWith('/') ? `${import.meta.env.BASE_URL}${mainImage}`.replace(/\/+/g, '/') : mainImage}
      alt={title}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
    />
    <!-- Difficulty badge -->
    <span class="absolute top-3 start-3 px-2.5 py-1 bg-white/90 backdrop-blur-sm text-stone-700 text-xs font-semibold rounded-full">
      {difficulty}
    </span>
  </div>

  <!-- Content -->
  <div class="flex flex-col flex-1 p-6">
    <h3 class="font-heading text-xl font-bold text-stone-900 leading-tight mb-1 line-clamp-2 min-h-[3.5rem]">
      <a href={tourLink} class="hover:text-terracotta transition-colors">{title}</a>
    </h3>
    <p class="text-stone-500 text-sm mb-4 italic line-clamp-3 min-h-[4.5rem]">{tagline}</p>

    <!-- Duration -->
    <div class="flex items-center gap-2 text-sm text-stone-600 mb-4">
      <svg class="w-4 h-4 text-terracotta flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <span>{t.tours.duration_label}: <strong>{duration}</strong></span>
    </div>

    {!compact && itinerary && (
      <div class="mb-5">
        <p class="font-semibold text-stone-700 text-xs mb-3 flex items-center gap-2">
          <svg class="w-4 h-4 text-terracotta" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A2 2 0 013 15.488V5.512a2 2 0 011.553-1.944L10 1.223a2 2 0 011.447 0l5.447 2.724A2 2 0 0118 5.877v9.976a2 2 0 01-1.553 1.944L10 21.777a2 2 0 01-1.447 0z" />
          </svg>
          {t.tours.itinerary_label}
        </p>
        <div class="relative ps-4 border-s-2 border-sand-200 space-y-3">
          {itinerary.map((step: string) => (
            <div class="relative">
              <div class="absolute -start-[1.35rem] top-1.5 w-2.5 h-2.5 rounded-full bg-sand-300 border-2 border-white"></div>
              <p class="text-xs text-stone-600 leading-relaxed">{step}</p>
            </div>
          ))}
        </div>
      </div>
    )}

    {!compact && (
      <div class="grid grid-cols-2 gap-4 mb-5 text-xs">
        <!-- Included -->
        <div>
          <p class="font-semibold text-stone-700 mb-2">{t.tours.included_label}</p>
          <ul class="space-y-1">
            {included.map((item: string) => (
              <li class="flex items-start gap-1.5 text-stone-500">
                <svg class="w-3.5 h-3.5 text-olive mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <!-- Not included -->
        <div>
          <p class="font-semibold text-stone-700 mb-2">{t.tours.not_included_label}</p>
          <ul class="space-y-1">
            {not_included.map((item: string) => (
              <li class="flex items-start gap-1.5 text-stone-500">
                <svg class="w-3.5 h-3.5 text-stone-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    )}

    <!-- Price + CTA -->
    <div class="mt-auto flex items-center justify-between pt-4 border-t border-stone-100">
      <div>
        <p class="text-xs text-stone-400 uppercase tracking-wide">{t.tours.price_label}</p>
        <p class="text-sm font-semibold text-stone-700">{price || t.tours.price_value}</p>
      </div>
      <div class="flex items-center gap-2">
        <a
          href={tourLink}
          class="text-stone-400 hover:text-stone-600 transition-colors p-2"
          title="View Details"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </a>
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary text-xs px-4 py-2.5 whitespace-nowrap"
        >
          {t.tours.reserve_button}
        </a>
      </div>
    </div>
  </div>
</article>
