---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import { getCollection } from 'astro:content';
import { useTranslations, LANGS, type Lang } from '../../utils/i18n';
import { SITE } from '../../config';

export async function getStaticPaths() {
  return LANGS.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);

const aboutEntries = await getCollection('about', ({ data }) => data.lang === lang);
const aboutEntry = aboutEntries[0];
const { Content } = await aboutEntry.render();

// Split sections on hr (---)
const sections = [t.about.section_story, t.about.section_perspective, t.about.section_beyond];
---

<BaseLayout title={t.about.page_title} lang={lang}>

  <!-- Page header -->
  <section class="relative py-24 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/shots/shot-18.jpg" alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-olive-dark/80"></div>
    </div>
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-white mb-4">{t.about.page_title}</h1>
    </div>
  </section>

  <!-- Main content -->
  <section class="py-20 bg-sand-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">

        <!-- Sidebar: photo + credentials -->
        <aside class="lg:col-span-2 space-y-6">
          <div class="rounded-2xl overflow-hidden shadow-lg aspect-[3/4]">
            <img
              src="/images/shots/shot-22.jpg"
              alt="Hamza — Guide touristique"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>

          <!-- Credential cards -->
          <div class="card p-5 space-y-4">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-terracotta-50 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-terracotta" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-stone-800 text-sm">{t.about.badge_label}</p>
                <p class="text-stone-400 text-xs">{t.about.years} {t.about.years_label}</p>
              </div>
            </div>

            <div class="flex items-center gap-3 pt-3 border-t border-stone-100">
              <div class="w-10 h-10 rounded-full bg-gold-50 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-stone-800 text-sm">{t.about.languages_label}</p>
                <p class="text-stone-400 text-xs">{t.about.languages_value}</p>
              </div>
            </div>
          </div>

          <a href={SITE.bookingUrl} target="_blank" rel="noopener noreferrer" class="btn-primary w-full text-center block">
            {t.about.cta_label}
          </a>
        </aside>

        <!-- Main text -->
        <div class="lg:col-span-3 space-y-10">
          <!-- Quote highlight -->
          <blockquote class="border-s-4 border-terracotta ps-6 py-2">
            <p class="font-heading text-xl italic text-stone-700 leading-relaxed">"{t.about.quote}"</p>
          </blockquote>

          <!-- Rendered markdown sections -->
          <div class="prose prose-stone prose-lg max-w-none
                      prose-headings:font-heading prose-headings:font-bold
                      prose-p:text-stone-600 prose-p:leading-relaxed
                      prose-hr:my-8 prose-hr:border-stone-200">
            <Content />
          </div>
        </div>

      </div>
    </div>
  </section>

  <CtaBanner lang={lang} />

</BaseLayout>
