---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FaqAccordion from '../../components/FaqAccordion.astro';
import { useTranslations, LANGS, type Lang } from '../../utils/i18n';
import { SITE } from '../../config';

export async function getStaticPaths() {
  return LANGS.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
const isRTL = lang === 'ar';
---

<BaseLayout title={t.contact.page_title} lang={lang}>

  <!-- Page header -->
  <section class="relative py-24 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/shots/shot-16.jpg" alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-olive-dark/80"></div>
    </div>
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-white mb-4">{t.contact.page_title}</h1>
      <p class="text-stone-300 text-lg">{t.contact.page_subtitle}</p>
    </div>
  </section>

  <!-- Contact section -->
  <section class="py-20 bg-sand-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">

        <!-- Contact info + quick links -->
        <aside class="lg:col-span-2 space-y-6">

          <!-- WhatsApp -->
          <a
            href={SITE.whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-4 p-5 bg-white rounded-2xl shadow-sm border border-stone-100 hover:shadow-md transition-shadow group"
          >
            <div class="w-12 h-12 rounded-full bg-green-50 flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-green-500" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <div>
              <p class="font-semibold text-stone-800 text-sm group-hover:text-terracotta transition-colors">{t.contact.whatsapp_label}</p>
              <p class="text-stone-500 text-xs">{SITE.whatsappNumber}</p>
            </div>
          </a>

          <!-- Email -->
          <a
            href={`mailto:${SITE.email}`}
            class="flex items-center gap-4 p-5 bg-white rounded-2xl shadow-sm border border-stone-100 hover:shadow-md transition-shadow group"
          >
            <div class="w-12 h-12 rounded-full bg-terracotta-50 flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-terracotta" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="font-semibold text-stone-800 text-sm group-hover:text-terracotta transition-colors">{t.contact.email_label}</p>
              <p class="text-stone-500 text-xs">{SITE.email}</p>
            </div>
          </a>

          <!-- Map embed -->
          <div class="rounded-2xl overflow-hidden shadow-sm border border-stone-100 aspect-video">
            <iframe
              src="https://www.openstreetmap.org/export/embed.html?bbox=1.2317657470703125%2C34.8261285737863%2C1.3580322265625%2C34.91596228863064&layer=mapnik"
              class="w-full h-full border-0"
              title="Tlemcen map"
              loading="lazy"
            ></iframe>
          </div>
        </aside>

        <!-- Contact form + FAQ -->
        <div class="lg:col-span-3 space-y-10">

          <!-- Form -->
          <div class="bg-white rounded-2xl shadow-sm border border-stone-100 p-8">
            <form
              name="contact"
              method="POST"
              data-netlify="true"
              data-netlify-honeypot="bot-field"
              class="space-y-5"
            >
              <input type="hidden" name="form-name" value="contact" />
              <input type="hidden" name="bot-field" class="hidden" />

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label class="block text-sm font-medium text-stone-700 mb-1.5">{t.contact.form_name}</label>
                  <input
                    type="text"
                    name="name"
                    required
                    class="w-full px-4 py-3 border border-stone-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-terracotta/30 focus:border-terracotta transition-colors bg-stone-50"
                  />
                </div>
                <div>
                  <label class="block text-sm font-medium text-stone-700 mb-1.5">{t.contact.form_email}</label>
                  <input
                    type="email"
                    name="email"
                    required
                    class="w-full px-4 py-3 border border-stone-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-terracotta/30 focus:border-terracotta transition-colors bg-stone-50"
                  />
                </div>
              </div>

              <div>
                <label class="block text-sm font-medium text-stone-700 mb-1.5">{t.contact.form_lang}</label>
                <select
                  name="preferred_language"
                  class="w-full px-4 py-3 border border-stone-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-terracotta/30 focus:border-terracotta transition-colors bg-stone-50"
                >
                  <option value="fr">Français</option>
                  <option value="en">English</option>
                  <option value="ar">العربية</option>
                </select>
              </div>

              <div>
                <label class="block text-sm font-medium text-stone-700 mb-1.5">{t.contact.form_message}</label>
                <textarea
                  name="message"
                  rows="5"
                  required
                  class="w-full px-4 py-3 border border-stone-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-terracotta/30 focus:border-terracotta transition-colors bg-stone-50 resize-none"
                ></textarea>
              </div>

              <button type="submit" class="btn-primary w-full text-center text-sm py-3">
                {t.contact.form_submit}
              </button>
            </form>
          </div>

          <!-- FAQ -->
          <div>
            <h2 class="font-heading text-2xl font-bold text-stone-900 mb-6">{t.contact.faq_title}</h2>
            <FaqAccordion faqs={t.contact.faqs} />
          </div>

        </div>
      </div>
    </div>
  </section>

</BaseLayout>
