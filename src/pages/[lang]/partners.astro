---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HotelPartnersSection from '../../components/HotelPartnersSection.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import { useTranslations, LANGS, type Lang } from '../../utils/i18n';

export async function getStaticPaths() {
  return LANGS.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
const isRTL = lang === 'ar';
---

<BaseLayout title={t.partners.page_title} lang={lang}>

  <!-- Page header -->
  <section class="relative py-24 bg-olive-dark overflow-hidden">
    <div class="absolute inset-0 opacity-20">
      <img
        src={`${import.meta.env.BASE_URL}/images/shots/shot-17.jpg`.replace(/\/+/g, '/')}
        alt=""
        class="w-full h-full object-cover"
      />
    </div>
    <!-- Gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-r from-olive-dark/80 to-olive-dark/40" />

    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <span class="inline-block px-4 py-1.5 bg-gold/20 text-gold text-xs font-bold uppercase tracking-widest rounded-full mb-6">
        🏨 {t.partners.section_title}
      </span>
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-white mb-4" dir={isRTL ? 'rtl' : 'ltr'}>
        {t.partners.page_title}
      </h1>
      <p class="text-stone-300 text-lg" dir={isRTL ? 'rtl' : 'ltr'}>
        {t.partners.page_subtitle}
      </p>
    </div>
  </section>

  <!-- Hotel cards (full grid, not compact) -->
  <HotelPartnersSection lang={lang} compact={false} />

  <!-- CTA to book a tour -->
  <CtaBanner lang={lang} />

</BaseLayout>
