---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TestimonialCard from '../../components/TestimonialCard.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import { useTranslations, LANGS, type Lang } from '../../utils/i18n';
import { SITE } from '../../config';
import testimonialData from '../../data/testimonials.json';

export async function getStaticPaths() {
  return LANGS.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
---

<BaseLayout title={t.testimonials.page_title} lang={lang}>

  <!-- Page header -->
  <section class="relative py-24 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/shots/shot-06.jpg" alt="" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-stone-900/70"></div>
    </div>
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-white mb-4">{t.testimonials.page_title}</h1>
      <p class="text-stone-300 text-lg">{t.testimonials.page_subtitle}</p>
    </div>
  </section>

  <!-- Testimonials grid -->
  <section class="py-20 bg-sand-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {testimonialData.map(testimonial => (
          <TestimonialCard testimonial={testimonial} lang={lang} />
        ))}
      </div>
    </div>
  </section>

  <CtaBanner lang={lang} />

</BaseLayout>
