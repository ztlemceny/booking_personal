---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { useTranslations, type Lang } from '../../../utils/i18n';
import { SITE } from '../../../config';

export async function getStaticPaths() {
  const tours = await getCollection('tours');
  return tours.map(tour => {
    const [slug] = tour.slug.split('.');
    return {
      params: { 
        lang: tour.data.lang,
        slug: slug
      },
      props: { tour },
    };
  });
}

const { tour } = Astro.props;
const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);

const { title, tagline, duration, difficulty, images, included, not_included, price, itinerary } = tour.data;
const { Content } = await tour.render();

const mainImage = images[0] ?? '/images/shots/shot-01.jpg';

const whatsappMessage = t.tours.whatsapp_message_template
  .replace('{title}', title)
  .replace('{price}', price || t.tours.price_value);
const whatsappUrl = `${SITE.whatsappUrl}?text=${encodeURIComponent(whatsappMessage)}`;

// Get other tours for recommendations
const allTours = await getCollection('tours', ({ data }) => data.lang === lang);
const otherTours = allTours
  .filter(item => item.id !== tour.id)
  .sort(() => 0.5 - Math.random())
  .slice(0, 3);
---

<BaseLayout title={title} lang={lang}>

  <!-- Hero / Header Image -->
  <section class="relative h-[60vh] min-h-[400px] overflow-hidden">
    <div class="absolute inset-0 watermark">
      <img src={mainImage.startsWith('/') ? `${import.meta.env.BASE_URL}${mainImage}`.replace(/\/+/g, '/') : mainImage} alt={title} class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-stone-900/40"></div>
    </div>
    <div class="relative h-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-end pb-12">
      <div class="max-w-3xl">
        <span class="inline-block px-3 py-1 bg-terracotta text-white text-xs font-bold rounded-full mb-4 uppercase tracking-widest">
          {duration} • {difficulty}
        </span>
        <h1 class="font-heading text-4xl md:text-6xl font-bold text-white mb-4 drop-shadow-lg">{title}</h1>
        <p class="text-xl text-stone-100 font-medium italic drop-shadow-md">{tagline}</p>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        
        <!-- Left: Description & Itinerary -->
        <div class="lg:col-span-2 space-y-12">
          
          <!-- Body text -->
          <div class="prose prose-stone prose-lg max-w-none">
            <Content />
          </div>

          <!-- Itinerary -->
          {itinerary && (
            <div class="bg-sand-50 rounded-3xl p-8 md:p-10 border border-sand-200">
              <h2 class="font-heading text-2xl font-bold text-stone-900 mb-8 flex items-center gap-3">
                <svg class="w-7 h-7 text-terracotta" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A2 2 0 013 15.488V5.512a2 2 0 011.553-1.944L10 1.223a2 2 0 011.447 0l5.447 2.724A2 2 0 0118 5.877v9.976a2 2 0 01-1.553 1.944L10 21.777a2 2 0 01-1.447 0z" />
                </svg>
                {t.tours.itinerary_label}
              </h2>
              <div class="relative ps-6 border-s-2 border-terracotta/20 space-y-8">
                {itinerary.map((step) => (
                  <div class="relative">
                    <div class="absolute -start-[2.15rem] top-1.5 w-4 h-4 rounded-full bg-terracotta border-4 border-white shadow-sm"></div>
                    <p class="text-lg text-stone-700 leading-relaxed font-medium">{step}</p>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Photo gallery for this tour -->
          {images.length > 1 && (
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {images.slice(1).map((img) => (
                <div class="rounded-2xl overflow-hidden aspect-video watermark">
                  <img src={img.startsWith('/') ? `${import.meta.env.BASE_URL}${img}`.replace(/\/+/g, '/') : img} alt={title} class="w-full h-full object-cover" />
                </div>
              ))}
            </div>
          )}
        </div>

        <!-- Right: Sidebar Info & Booking -->
        <aside class="space-y-6">
          <div class="sticky top-24 space-y-6">
            
            <!-- Details Card -->
            <div class="bg-white rounded-3xl p-6 border border-stone-100 shadow-sm space-y-6">
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-xs text-stone-400 uppercase tracking-widest mb-1">{t.tours.price_label}</p>
                  <p class="text-3xl font-bold text-stone-900">{price || t.tours.price_value}</p>
                </div>
              </div>

              <hr class="border-stone-100" />

              <div class="space-y-4">
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-terracotta mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <div>
                    <p class="text-xs text-stone-400 uppercase tracking-widest">{t.tours.duration_label}</p>
                    <p class="font-bold text-stone-700">{duration}</p>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-terracotta mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                  </svg>
                  <div>
                    <p class="text-xs text-stone-400 uppercase tracking-widest">Difficulty</p>
                    <p class="font-bold text-stone-700">{difficulty}</p>
                  </div>
                </div>
              </div>

              <div class="grid grid-cols-1 gap-6 pt-4">
                <div>
                  <p class="font-bold text-stone-900 mb-3 text-sm">{t.tours.included_label}</p>
                  <ul class="space-y-2">
                    {included.map((item) => (
                      <li class="flex items-start gap-2 text-stone-600 text-sm">
                        <svg class="w-4 h-4 text-olive mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                        </svg>
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
                <div>
                  <p class="font-bold text-stone-900 mb-3 text-sm">{t.tours.not_included_label}</p>
                  <ul class="space-y-2">
                    {not_included.map((item) => (
                      <li class="flex items-start gap-2 text-stone-400 text-sm italic">
                        <svg class="w-4 h-4 text-stone-300 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>

              <a
                href={whatsappUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="block w-full text-center py-4 bg-terracotta text-white font-bold rounded-2xl shadow-lg hover:bg-terracotta-dark transition-all transform hover:-translate-y-1 active:scale-95"
              >
                {t.tours.reserve_button}
              </a>
            </div>

            <!-- Help card -->
            <div class="bg-olive-dark rounded-3xl p-6 text-white">
              <h3 class="font-heading text-lg font-bold mb-2">Need Help?</h3>
              <p class="text-white/70 text-sm mb-4 leading-relaxed">
                Have questions about this tour or want to customize your experience? Contact me directly.
              </p>
              <a href={`mailto:${SITE.email}`} class="text-gold font-bold hover:underline">
                {SITE.email}
              </a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Other Tours -->
  <section class="py-20 bg-sand-50 border-t border-sand-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl font-bold text-stone-900 mb-10 text-center">Other Experiences</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {otherTours.map((item) => {
           const [s] = item.slug.split('.');
           const link = `${import.meta.env.BASE_URL}/${lang}/tours/${s}`.replace(/\/+/g, '/');
           const tourImage = item.data.images[0];
           const tourImgSrc = tourImage.startsWith('/') ? `${import.meta.env.BASE_URL}${tourImage}`.replace(/\/+/g, '/') : tourImage;
           return (
            <a href={link} class="group bg-white rounded-3xl overflow-hidden shadow-sm border border-stone-100 hover:shadow-md transition-all">
              <div class="aspect-video watermark overflow-hidden">
                <img src={tourImgSrc} alt={item.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              </div>
              <div class="p-6">
                <h3 class="font-bold text-stone-900 group-hover:text-terracotta transition-colors line-clamp-1">{item.data.title}</h3>
                <p class="text-stone-500 text-sm mt-1">{item.data.duration}</p>
              </div>
            </a>
           );
        })}
      </div>
    </div>
  </section>

</BaseLayout>
